# =====================================================
#  Amigão Pet Shop — Atendimento WhatsApp
#  Copie este arquivo para .env e preencha os valores
# =====================================================

# Porta do servidor (padrão: 3000)
PORT=3000

# ── Evolution API (WhatsApp) ──────────────────────
# URL do seu servidor Evolution API
EVOLUTION_API_URL=http://localhost:8080
# Chave de API do Evolution
EVOLUTION_API_KEY=sua-chave-aqui
# Nome da instância criada no Evolution
EVOLUTION_INSTANCE=amigao

# ── Anthropic (Claude IA) ─────────────────────────
# Chave da API Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Dados do Pet Shop ─────────────────────────────
PETSHOP_NOME=Amigão Pet Shop
PETSHOP_ENDERECO=Rua dos Pets, 123 - Centro
PETSHOP_HORARIO=Seg-Sex 8h-18h | Sáb 8h-17h
PETSHOP_INSTAGRAM=@amigaopetshop
PETSHOP_WHATSAPP=(11) 9 9999-9999

# ── Dashboard Admin ───────────────────────────────
# Senha de acesso ao dashboard (troque antes de produção!)
DASHBOARD_PASSWORD=amigao2025

# ── Banco de Dados ────────────────────────────────
# Caminho para o arquivo SQLite
DB_PATH=./amigao.db
